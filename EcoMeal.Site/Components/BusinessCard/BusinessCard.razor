@using EcoMeal.Site.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS

<div class="card h-100 border-0 shadow-sm custom-card-hover" @onclick="NavigateToDetails">
    <div class="position-absolute top-0 end-0 m-3 z-1">
        <span class="badge bg-success bg-opacity-75 rounded-pill px-3 py-2 shadow-sm backdrop-blur">
            <i class="bi bi-leaf-fill me-1"></i> Eco
        </span>
    </div>

    <img src="@GetImageForBusinessType(Business.BusinessTypeName)" class="card-img-top custom-img-height"
         alt="@Business.Name">

    <div class="card-body d-flex flex-column text-center p-4">
        <h5 class="card-title fw-bold text-dark mb-1">@Business.Name</h5>
        <p class="text-muted small mb-3 fw-medium">
            <i class="bi bi-shop text-warning me-1"></i> @(string.IsNullOrEmpty(Business.BusinessTypeName) ? "Magazin" :
                                                                                                            Business.BusinessTypeName)
            @if (Business.DistanceInKm.HasValue)
            {
                <span class="badge bg-info text-dark ms-2 rounded-pill shadow-sm" style="font-size: 0.85em;">📍 @Business.DistanceInKm.Value.ToString("F1") km</span>
            }
        </p>

        <p class="card-text text-secondary mb-2 fs-6 d-flex align-items-center">
            <i class="bi bi-geo-alt-fill text-danger me-2"></i>
            <span class="text-truncate">@Business.Address</span>
        </p>
        <p class="card-text text-secondary mb-4 fs-6 d-flex align-items-center">
            <i class="bi bi-telephone-fill text-primary me-2"></i>
            @Business.Contact
        </p>

        <p class="card-text small text-muted mt-auto line-clamp-2">
            @Business.Description
        </p>
    </div>
    <AuthorizeView Roles="Admin">
        <div class="card-footer bg-transparent border-0 pb-3 pt-0">
            <button class="btn btn-outline-danger w-100 rounded-pill fw-semibold btn-hover-danger"
                    @onclick="ConfirmDelete" @onclick:stopPropagation="true">
                <i class="bi bi-trash3-fill me-2"></i> Șterge
            </button>
        </div>
    </AuthorizeView>

    <AuthorizeView Roles="Admin">
        <div class="mt-3 d-flex gap-2">
            <a href="/editBusiness/@Business.Id" class="btn btn-outline-primary btn-sm flex-grow-1 rounded-pill"
               @onclick:stopPropagation="true">
                <i class="bi bi-pencil-square me-1"></i> Editează
            </a>
        </div>
    </AuthorizeView>

</div>

<style>
    .custom-card-hover {
        border-radius: var(--radius-xl);
        overflow: hidden;
        transition: transform var(--transition-base), box-shadow var(--transition-base);
        cursor: pointer;
        border: 1px solid var(--eco-gray-100);
    }

    .custom-card-hover:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-xl) !important;
        border-color: var(--eco-primary-light);
    }

    .custom-img-height {
        height: 200px;
        object-fit: cover;
        transition: transform var(--transition-slow);
    }

    .custom-card-hover:hover .custom-img-height {
        transform: scale(1.05);
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .backdrop-blur {
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
    }

    .btn-hover-danger {
        transition: all var(--transition-base);
    }

    .btn-hover-danger:hover {
        background-color: var(--eco-danger);
        color: white;
        transform: scale(1.02);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);
    }
</style>

@code {
    [Parameter] public EventCallback<int> OnDeleteRequested { get; set; }

    private async Task ConfirmDelete()
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Ești sigur că vrei să ștergi acest business?");
        if (confirmed)
        {
            await OnDeleteRequested.InvokeAsync(Business.Id);
        }
    }
    private string GetImageForBusinessType(string? typeName)
    {
        string defaultImage = "https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=400&auto=format&fit=crop";

        if (string.IsNullOrWhiteSpace(typeName))
        {
            return defaultImage;
        }

        string lowerType = typeName.ToLower();

        if (lowerType.Contains("patiserie") || lowerType.Contains("brutarie"))
        {
            return "https://images.unsplash.com/photo-1509440159596-0249088772ff?q=80&w=400&auto=format&fit=crop";
        }
        else if (lowerType.Contains("pizza") || lowerType.Contains("pizzerie"))
        {
            return "https://images.unsplash.com/photo-1513104890138-7c749659a591?q=80&w=400&auto=format&fit=crop";
        }
        else if (lowerType.Contains("restaurant") || lowerType.Contains("bistro"))
        {
            return "https://images.unsplash.com/photo-1550966871-3ed3cdb5ed0c?q=80&w=400&auto=format&fit=crop";
        }
        else if (lowerType.Contains("supermarket") || lowerType.Contains("magazin") || lowerType.Contains("market"))
        {
            return "https://images.unsplash.com/photo-1578916171728-46686eac8d58?q=80&w=400&auto=format&fit=crop";
        }
        else if (lowerType.Contains("fast-food") || lowerType.Contains("fast food"))
        {
            return "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=400&auto=format&fit=crop";
        }

        return defaultImage;
    }
}