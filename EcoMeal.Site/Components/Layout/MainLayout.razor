@inherits LayoutComponentBase

<div class="page bg-light min-vh-100">
    <main>
        <nav class="navbar navbar-expand-lg bg-white shadow-sm px-4 mb-4 py-2">
            <div class="container-fluid d-flex justify-content-between align-items-center">

                <a class="navbar-brand d-flex align-items-center m-0 p-0 text-decoration-none" href="/">
                    <img src="/EcoMealImages/EcoMeal.logo.png" alt="EcoMeal Logo" height="100" class="me-2" />
                </a>

                <div class="d-flex align-items-center gap-3">

                    <a href="/login"
                       class="btn btn-success rounded-pill px-4 py-2 fw-semibold d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle fs-5 lh-1"></i>
                        <span class="lh-1">Sign In</span>
                    </a>

                    <a href="/register"
                       class="btn rounded-pill px-4 py-2 fw-semibold d-flex align-items-center gap-2 text-white"
                       style="background-color: #fd7e14; border: none;">
                        <i class="bi bi-person-plus-fill fs-5 lh-1"></i>
                        <span class="lh-1">Sign Up</span>
                    </a>

                </div>

            </div>
        </nav>

        <article class="content px-4 pb-5">
            @Body
        </article>
    </main>
</div>