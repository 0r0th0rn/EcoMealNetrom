@using EcoMeal.Site.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

@namespace EcoMeal.Site.Components.Layout

<nav class="navbar sticky-top p-0 px-2" style="height: 60px;">

    <a class="navbar-brand m-0" href="/">
        <img src="/EcoMealImages/EcoMeal.logo.png" alt="EcoMeal Logo"
             style="height: 50px; width: auto; object-fit: contain;">
    </a>

    <div class="mx-3 flex-grow-1 d-none d-sm-flex justify-content-center" style="max-width: 500px;">
        <SearchBar />
    </div>

    <div class="ms-auto d-flex align-items-center gap-3">
        @if (AuthService.IsAuthenticated)
        {
            <a class="btn btn-outline-secondary btn-sm me-2" href="/orders">Comenzi</a>
            <div class="d-flex align-items-center text-dark bg-light rounded-pill shadow-sm border">
                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center"
                     style="width: 36px; height: 36px; font-weight: 600;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                         class="bi bi-person-fill" viewBox="0 0 16 16">
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6" />
                    </svg>
                </div>
                <span class="fw-medium text-account px-2" style="font-size: 0.9rem;">Contul meu</span>
            </div>

            <button
                class="btn btn-light d-flex justify-content-center align-items-center btn-sm rounded-pill px-3 border shadow-sm fw-medium text-secondary hover-danger"
                @onclick="HandleLogout">
                <span class="material-symbols-outlined">
                    logout
                </span>Deconectare
            </button>
        }
        else
        {
            <a class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm fw-medium" href="/login">
                Autentificare
            </a>
        }
    </div>
</nav>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.LoadTokenAsync();
            StateHasChanged();
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}