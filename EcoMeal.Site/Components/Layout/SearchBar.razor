@using System.Timers
@using EcoMeal.Site.Models
@using EcoMeal.Site.Services
@implements IDisposable
@inject BusinessService BusinessService

<div class="search-container">
    <div class="search-input-wrapper d-flex align-items-center bg-light border rounded-pill shadow-sm px-3">

        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
             class="bi bi-search text-secondary opacity-75" viewBox="0 0 16 16">
            <path
            d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
        </svg>

        <input type="text" class="form-control border-0 bg-transparent shadow-none px-2 py-2 fw-medium text-dark"
               style="font-size: 0.95rem;" placeholder="Caută afaceri sau pachete..." @bind="SearchTerm"
               @bind:event="oninput" />

        @if (IsSearching)
        {
            <div class="spinner-border spinner-border-sm text-primary ms-2 opacity-75" role="status">
                <span class="visually-hidden">Se caută...</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(SearchTerm) && !IsSearching)
        {
            <button class="btn btn-link p-0 text-secondary ms-2 opacity-75 hover-opacity-100" @onclick="ClearSearch">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path
                    d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
        }
    </div>

    @if (ShowResults)
    {
        <div class="search-results-dropdown shadow-lg border-0 bg-white">

            @if (FilteredBusinesses.Any())
            {
                <h6 class="dropdown-section-title">Afaceri</h6>
                <ul class="list-unstyled mb-0 pb-1">
                    @foreach (var business in FilteredBusinesses)
                    {
                        <li>
                            <a class="search-result-item" href="/business/@business.Id" @onclick="ClearSearch">
                                <!-- Iconiță Magazin -->
                                <svg class="search-result-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                     fill="currentColor" viewBox="0 0 16 16">
                                    <path
                                    d="M2.97 1.35A1 1 0 0 1 3.73 1h8.54a1 1 0 0 1 .76.35l2.609 3.044A1.5 1.5 0 0 1 16 5.37v.255a2.375 2.375 0 0 1-4.25 1.458A2.371 2.371 0 0 1 9.875 8 2.37 2.37 0 0 1 8 7.083 2.37 2.37 0 0 1 6.125 8a2.37 2.37 0 0 1-1.875-.917A2.375 2.375 0 0 1 0 5.625V5.37a1.5 1.5 0 0 1 .361-.976l2.61-3.045zm1.78 4.275a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 1 0 2.75 0V5.37a.5.5 0 0 0-.12-.325L12.27 2H3.73L1.12 5.045A.5.5 0 0 0 1 5.37v.255a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0zM1.5 8.5A.5.5 0 0 1 2 9v6h1v-5a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v5h6V9a.5.5 0 0 1 1 0v6h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1V9a.5.5 0 0 1 .5-.5zM4 15h3v-5H4v5zm5-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3z" />
                                </svg>
                                <span>@business.Name</span>
                            </a>
                        </li>
                    }
                </ul>
            }

            @if (FilteredPackages.Any())
            {
                <h6 class="dropdown-section-title @(FilteredBusinesses.Any() ? "border-top" : "")">Pachete</h6>
                <ul class="list-unstyled mb-0 pb-1">
                    @foreach (var package in FilteredPackages)
                    {
                        <li>
                            <a class="search-result-item" href="/business/@package.BusinessId#pkg-@package.Id"
                               @onclick="ClearSearch">
                                <!-- Iconiță Pachet -->
                                <svg class="search-result-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                     fill="currentColor" viewBox="0 0 16 16">
                                    <path
                                    d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2l-2.218-.887zm3.564 1.426L5.596 5 8 5.961 14.154 3.5l-2.404-.961zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923l6.5 2.6zM7.443.184a1.5 1.5 0 0 1 1.114 0l7.129 2.852A.5.5 0 0 1 16 3.5v8.662a1 1 0 0 1-.629.928l-7.185 2.874a.5.5 0 0 1-.372 0L.63 13.09a1 1 0 0 1-.63-.928V3.5a.5.5 0 0 1 .314-.464L7.443.184z" />
                                </svg>
                                <span>@package.Name</span>
                            </a>
                        </li>
                    }
                </ul>
            }

            @if (!FilteredBusinesses.Any() && !FilteredPackages.Any())
            {
                <div class="p-4 text-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor"
                         class="bi bi-search text-muted opacity-25 mb-2" viewBox="0 0 16 16">
                        <path
                        d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                    </svg>
                    <p class="text-muted small mb-0">Nu am găsit rezultate pentru<br /> <strong
                        class="text-dark">"@SearchTerm"</strong></p>
                    </div>
                }
            </div>
        }
    </div>

@code {
    private string _searchTerm = string.Empty;
    private Timer? _debounceTimer;

    public string SearchTerm
    {
        get => _searchTerm;
        set
        {
            _searchTerm = value;
            _debounceTimer?.Stop();
            _debounceTimer?.Start();
        }
    }

    private bool IsSearching { get; set; }
    private bool ShowResults => !string.IsNullOrWhiteSpace(SearchTerm) && !IsSearching;

    private List<BusinessModel> FilteredBusinesses = new();
    private List<PackageGetModel> FilteredPackages = new();

    protected override void OnInitialized()
    {
        _debounceTimer = new Timer(400);
        _debounceTimer.AutoReset = false;
        _debounceTimer.Elapsed += async (sender, args) => await PerformSearchAsync();
    }

    private async Task PerformSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(SearchTerm) || SearchTerm.Length < 2)
        {
            ClearResults();
            return;
        }

        IsSearching = true;
        await InvokeAsync(StateHasChanged);

        var searchResult = await BusinessService.SearchAsync(SearchTerm);

        FilteredBusinesses = searchResult.Businesses ?? new();
        FilteredPackages = searchResult.Packages ?? new();

        IsSearching = false;
        await InvokeAsync(StateHasChanged);
    }

    private void ClearSearch()
    {
        SearchTerm = string.Empty;
        ClearResults();
    }

    private void ClearResults()
    {
        FilteredBusinesses.Clear();
        FilteredPackages.Clear();
        IsSearching = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}