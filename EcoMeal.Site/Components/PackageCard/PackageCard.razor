@namespace EcoMeal.Site.Components.PackageCard
@using EcoMeal.Site.Models
@using EcoMeal.Site.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager
@inject OrderService OrderService

<div class="card h-100 border-0 shadow-sm pkg-card-hover">
    <div class="position-relative">
        <img src="@GetImageForPackageType(Package.PackageTypeName)" class="card-img-top pkg-img-height"
             alt="@Package.Name">

        <!-- Badge Tip Pachet -->
        <div class="position-absolute top-0 start-0 m-3">
            <span class="badge bg-primary bg-opacity-75 rounded-pill px-3 py-2 shadow-sm pkg-backdrop-blur">
                <i class="bi bi-box-seam-fill me-1"></i> @Package.PackageTypeName
            </span>
        </div>

        <!-- Secțiune Prețuri -->
        <div class="position-absolute bottom-0 end-0 m-3 d-flex flex-column align-items-end">
            @if (Package.OldPrice > 0 && Package.OldPrice > Package.Price)
            {
                <span class="badge bg-danger rounded-pill px-2 py-1 shadow-sm mb-1 pkg-backdrop-blur"
                      style="text-decoration: line-through; opacity: 0.9; font-size: 0.75rem;">
                    @Package.OldPrice.ToString("F2") RON
                </span>
            }
            <span class="badge bg-warning text-dark rounded-pill px-3 py-2 shadow fw-bold fs-6">
                @Package.Price.ToString("F2") RON
            </span>
        </div>
    </div>

    <div class="card-body d-flex flex-column">
        <h5 class="card-title fw-bold text-dark mb-2">@Package.Name</h5>

        @if (!string.IsNullOrWhiteSpace(Package.Description))
        {
            <p class="card-text text-secondary small mb-3 pkg-line-clamp-2">
                @Package.Description
            </p>
        }

        <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom border-light">
            <span
                class="badge bg-info text-dark bg-opacity-10 border border-info rounded-pill px-2 py-1 small fw-medium">
                <i class="bi bi-boxes me-1"></i> @Package.AvailableQty buc.
            </span>
            <span class="text-secondary small fw-medium">
                <i class="bi bi-minecart-loaded me-1"></i> @Package.weightInKg kg
            </span>
        </div>

        <div class="mt-auto">
            <div class="d-flex align-items-center text-secondary small mb-2">
                <i class="bi bi-clock-fill text-success me-2"></i>
                <span><strong>Start:</strong> @Package.StartPickup.ToString("dd.MM.yyyy HH:mm")</span>
            </div>
            <div class="d-flex align-items-center text-secondary small">
                <i class="bi bi-clock-history text-danger me-2"></i>
                <span><strong>End:</strong> @Package.EndPickup.ToString("dd.MM.yyyy HH:mm")</span>
            </div>
        </div>
    </div>

    <AuthorizeView Roles="Admin">
        <div class="card-footer bg-transparent border-0 pb-3 pt-0">
            <button class="btn btn-outline-warning btn-sm rounded-pill px-3" @onclick="NavigateToEdit">
                <i class="bi bi-pencil-fill me-2"></i> Editează
            </button>
            <button class="btn btn-outline-danger btn-sm rounded-pill px-3" @onclick="OnDeleteClicked">
                <i class="bi bi-trash me-1"></i> Șterge
            </button>
        </div>
    </AuthorizeView>

    <AuthorizeView Roles="User">
        <div class="card-footer bg-transparent border-0 pb-3 pt-0 text-center">
            <button class="btn btn-primary rounded-pill px-4 shadow-sm w-100 btn-hover-effect" @onclick="OnOrderClicked"
                    disabled="@(isOrdering || Package.AvailableQty <= 0 || IsExpired)">

                @if (isOrdering)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Se procesează...</span>
                }
                else if (IsExpired)
                {
                    <i class="bi bi-calendar-x me-2"></i> <span>Expirat</span>
                }
                else if (Package.AvailableQty <= 0)
                {
                    <i class="bi bi-x-circle me-2"></i> <span>Stoc Epuizat</span>
                }
                else
                {
                    <i class="bi bi-cart-plus me-2"></i> <span>Comandă</span>
                }
            </button>

            @if (orderSuccess.HasValue)
            {
                <div class="mt-2 small @(orderSuccess.Value ? "text-success" : "text-danger")">
                    @(orderSuccess.Value ? "Comandă plasată cu succes!" : "Eroare la plasarea comenzii.")
                </div>
            }
        </div>
    </AuthorizeView>
</div>

<style>
    .pkg-card-hover {
        border-radius: 1rem;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: default;
    }

    .pkg-card-hover:hover {
        transform: translateY(-6px);
        box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.12) !important;
    }

    .pkg-img-height {
        height: 180px;
        object-fit: cover;
    }

    .pkg-line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .pkg-backdrop-blur {
        backdrop-filter: blur(4px);
    }

    .btn-hover-edit {
        transition: all 0.2s;
    }

    .btn-hover-edit:hover {
        background-color: #ffc107;
        color: #212529;
        transform: scale(1.02);
    }
</style>

@code {
    [Parameter]
    public required PackageGetModel Package { get; set; }

    [Parameter]
    public int BusinessId { get; set; }
    private bool IsExpired => Package.EndPickup < DateTime.Now;
    private void NavigateToEdit()
    {
        NavigationManager.NavigateTo($"/business/{BusinessId}/editPackage/{Package.Id}");
    }

    [Parameter] public EventCallback<int> OnPackageDeleted { get; set; }

    [Inject] public required BusinessService BusinessService { get; set; }

    private bool isOrdering = false;
    private bool? orderSuccess = null;

    private async Task OnDeleteClicked()
    {
        var succes = await BusinessService.DeletePackageAsync(Package.Id);
        if (succes)
        {
            await OnPackageDeleted.InvokeAsync(Package.Id);
        }
    }

    private async Task OnOrderClicked()
    {
        if (Package.AvailableQty <= 0) return;

        isOrdering = true;
        orderSuccess = null;
        StateHasChanged();

        var success = await OrderService.PlaceOrderAsync(Package.Id);
        orderSuccess = success;

        isOrdering = false;
        StateHasChanged();
    }

    private string GetImageForPackageType(string? typeName)
    {
        string defaultImage = "https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=400&auto=format&fit=crop";

        if (string.IsNullOrWhiteSpace(typeName))
        {
            return defaultImage;
        }

        string lowerType = typeName.ToLower();

        if (lowerType.Contains("vegetarian"))
        {
            return "https://images.unsplash.com/photo-1512621776951-a57141f2eefd?q=80&w=400&auto=format&fit=crop";
        }
        else if (lowerType.Contains("surprise"))
        {
            return
"https://plus.unsplash.com/premium_photo-1728412897842-06f0fc4c2ec6?q=80&w=1245&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
        }
        else if (lowerType.Contains("lactate"))
        {
            return
"https://images.unsplash.com/photo-1627935722051-395636b0d8a5?q=80&w=1173&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
        }
        else if (lowerType.Contains("patiserie"))
        {
            return
"https://images.unsplash.com/photo-1483695028939-5bb13f8648b0?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
        }
        else if (lowerType.Contains("fructe"))
        {
            return
"https://images.unsplash.com/photo-1610832958506-aa56368176cf?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
        }
        else if (lowerType.Contains("bacanie"))
        {
            return
"https://images.unsplash.com/photo-1600626324898-5af3796f6536?q=80&w=1274&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
        }
        return defaultImage;
    }
}