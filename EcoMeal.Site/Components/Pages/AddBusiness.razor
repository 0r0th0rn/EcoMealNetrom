@page "/addBusiness"
@rendermode InteractiveServer

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-4 border-0">
                    <h3 class="mb-1 fw-bold text-shadow-sm">Adaugă Afacere Nouă</h3>
                    <p class="mb-0 text-white-50 small">Completează detaliile pentru noua afacere</p>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <EditForm Model="BusinessAddModel" OnValidSubmit="SaveBusiness">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary">Nume Afacere</label>
                            <InputText class="form-control form-control-lg" @bind-Value="BusinessAddModel.Name" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary">Adresă</label>
                            <InputText class="form-control form-control-lg" @bind-Value="BusinessAddModel.Address" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary">Contact</label>
                            <InputText class="form-control form-control-lg" @bind-Value="BusinessAddModel.Contact" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary">Descriere</label>
                            <InputTextArea class="form-control" @bind-Value="BusinessAddModel.Description" rows="3" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary">Tip Afacere</label>
                            <InputSelect class="form-select form-select-lg"
                                         @bind-Value="BusinessAddModel.BusinessTypeId">
                                <option value="0" disabled selected>-- Alege tipul afacerii --</option>

                                @foreach (var type in BusinessTypes)
                                {
                                    <option value="@type.Id">@type.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <button type="button" class="btn btn-light px-4 rounded-pill" @onclick="GoBack">
                                <i class="bi bi-arrow-left me-2"></i> Înapoi
                            </button>
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                                <i class="bi bi-check2-circle me-2"></i> Salvează
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>