@page "/business/{BusinessId:int}/addPackage"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <!-- Header -->
                <div class="card-header bg-primary text-white p-4 border-0">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-25 rounded-circle p-3 me-3 d-flex align-items-center justify-content-center"
                             style="width: 60px; height: 60px;">
                            <i class="bi bi-box-seam fs-2"></i>
                        </div>

                        <div>
                            <h3 class="mb-1 fw-bold text-shadow-sm">Adaugă Pachet Nou</h3>
                            <p class="mb-0 text-white-50 small">Completează detaliile pentru noul pachet al afacerii</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <EditForm Model="PackageAddModel" OnValidSubmit="AddPackageToBusiness">
                        <DataAnnotationsValidator />

                        @if (context.GetValidationMessages().Any())
                        {
                            <div class="alert alert-danger shadow-sm rounded-3 mb-4 d-flex align-items-start" role="alert">
                                <i class="bi bi-exclamation-triangle-fill fs-4 me-3 mt-1"></i>
                                <div>
                                    <h6 class="alert-heading fw-bold mb-1">Eroare de validare</h6>
                                    <ValidationSummary class="mb-0 text-danger small list-unstyled" />
                                </div>
                            </div>
                        }

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary">Nume Pachet</label>
                            <InputText
                            class="form-control form-control-lg rounded-3 bg-light border-0 shadow-none custom-focus"
                            @bind-Value="PackageAddModel.Name" placeholder="Ex: Pachet Vegetarian Zilnic" />
                            <ValidationMessage For="@(() => PackageAddModel.Name)"
                                               class="text-danger small mt-1 fw-medium"></ValidationMessage>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary">Descriere</label>
                            <InputTextArea class="form-control rounded-3 bg-light border-0 shadow-none custom-focus"
                                           @bind-Value="PackageAddModel.Description" placeholder="Ce conține acest pachet?"
                                           rows="3" />
                            <ValidationMessage For="@(() => PackageAddModel.Description)"
                                               class="text-danger small mt-1 fw-medium"></ValidationMessage>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Tip pachet</label>
                                <InputSelect @bind-Value="PackageAddModel.PackageTypeId"
                                             class="form-select form-select-lg rounded-3 bg-light border-0 shadow-none custom-focus">
                                    <option value="0" disabled>Alege tipul...</option>
                                    @foreach (var packageType in PackageTypes)
                                    {
                                        <option value="@packageType.Id">@packageType.Name</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">Preț (RON)</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0 bg-light rounded-start-3 text-secondary"><i
                                        class="bi bi-tag-fill"></i></span>
                                        <InputNumber
                                        class="form-control form-control-lg rounded-end-3 bg-light border-0 shadow-none custom-focus"
                                        @bind-Value="PackageAddModel.Price" placeholder="0.00" />
                                    </div>
                                </div>
                            </div>

                            <div class="row g-4 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold text-secondary">Start Pick-up</label>
                                    <div class="input-group">
                                        <span class="input-group-text border-0 bg-light rounded-start-3 text-secondary"><i
                                            class="bi bi-clock"></i></span>
                                            <InputDate @bind-Value="PackageAddModel.StartPickup"
                                                       Type="InputDateType.DateTimeLocal"
                                                       class="form-control rounded-end-3 bg-light border-0 shadow-none custom-focus" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold text-secondary">End Pick-up</label>
                                        <div class="input-group">
                                            <span class="input-group-text border-0 bg-light rounded-start-3 text-secondary"><i
                                                class="bi bi-clock-history"></i></span>
                                                <InputDate @bind-Value="PackageAddModel.EndPickup"
                                                           Type="InputDateType.DateTimeLocal"
                                                           class="form-control rounded-end-3 bg-light border-0 shadow-none custom-focus" />
                                            </div>
                                        </div>
                                    </div>

                                    <hr class="my-5 text-muted border-secondary opacity-25">

                                    <div class="d-flex justify-content-between align-items-center">
                                        <button type="button"
                                                class="btn btn-light text-secondary fw-medium rounded-pill px-4 btn-hover-light"
                                                @onclick="GoBack">
                                            <i class="bi bi-arrow-left me-2"></i> Înapoi
                                        </button>
                                        <button type="submit"
                                                class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm custom-btn-hover">
                                            <i class="bi bi-check2-circle me-2"></i> Salvează Pachetul
                                        </button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <style>
                .custom-focus:focus {
                    background-color: #fff !important;
                    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
                    border: 1px solid #0d6efd !important;
                }

                .text-shadow-sm {
                    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
                }

                .custom-btn-hover {
                    transition: all 0.3s ease;
                }

                .custom-btn-hover:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 0.5rem 1rem rgba(13, 110, 253, 0.3) !important;
                }

                .btn-hover-light {
                    transition: background-color 0.2s ease;
                }

                .btn-hover-light:hover {
                    background-color: #e2e6ea;
                }
            </style>